{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simpl SSH",
  "version": "0.9.2",
  "identifier": "com.simplssh.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simpl SSH",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "minimumSystemVersion": "11.0"
    },
    "publisher": "yuanqinglong5413",
    "category": "DeveloperTool",
    "shortDescription": "Lightweight Xshell + Xftp combined SSH client",
    "longDescription": "simpl-ssh is a lightweight SSH client that combines an interactive terminal and a file manager in one window, sharing a single SSH connection. Built with Rust + Tauri.",
    "copyright": "© 2026 yuanqinglong5413",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDc3MkFDODdCNDE4MkE5NkYKUldSdnFZSkJlOGdxZDFHNGdWVWE5Vld5ZHUzK3NJK3NHcHY3UkxiRVcwU1haTmR3YmNnd2hNaFcK",
      "endpoints": [
        "https://github.com/yuanqinglong5413/simpl-ssh-client/releases/latest/download/latest.json"
      ]
    }
  }
}
