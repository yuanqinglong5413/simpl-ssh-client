{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Simpl SSH",
  "version": "0.2.0",
  "identifier": "com.simplssh.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Simpl SSH",
        "width": 1200,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "yuanqinglong5413",
    "category": "DeveloperTool",
    "shortDescription": "Lightweight Xshell + Xftp combined SSH client",
    "longDescription": "simpl-ssh is a lightweight SSH client that combines an interactive terminal and a file manager in one window, sharing a single SSH connection. Built with Rust + Tauri.",
    "copyright": "© 2026 yuanqinglong5413",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
